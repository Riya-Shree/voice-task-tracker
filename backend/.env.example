# MongoDB Connection
# For local MongoDB Compass: mongodb://localhost:27017/task-tracker
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/task-tracker
MONGODB_URI=mongodb://localhost:27017/task-tracker

# Groq API Key
# Get your free API key from: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Server Port
PORT=5000